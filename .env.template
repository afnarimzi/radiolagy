# Google Gemini API Configuration (for Radiology Agent)
GOOGLE_API_KEY=your_radiology_gemini_api_key_here

# Groq API Configuration (for Clinical, Evidence, Risk, Chairman agents)
GROQ_API_KEY=your_groq_api_key_here

# Database Configuration
DATABASE_URL=postgresql://radiology_user:radiology_pass@database:5432/radiology_ai

# Application Configuration
APP_NAME=Radiology AI System
DEBUG=True

# Agent Configuration Notes:
# - Radiology Agent: Google Gemini Vision (image analysis)
# - Clinical Agent: Groq (differential diagnosis)
# - Evidence Agent: Groq (literature search)
# - Risk Agent: Groq DeepSeek-R1 (advanced reasoning for risk assessment)
# - Chairman Agent: Groq (final synthesis)

# -----------------------------------------------------------------------
# Dual-Model Radiology Validation Configuration (Req 6.5)
# All variables are optional — defaults are shown below
# -----------------------------------------------------------------------

# Validation thresholds
DUAL_CONFIDENCE_THRESHOLD=0.7        # Minimum confidence from both models (0.0–1.0)
DUAL_AGREEMENT_THRESHOLD=0.8         # Minimum inter-model agreement (0.0–1.0)
DUAL_QUALITY_THRESHOLD=adequate      # Minimum image quality: excellent|good|adequate|poor
DUAL_MAX_RETRIES=2                   # Max retry attempts for borderline cases (0–5)
DUAL_REQUIRE_CONSENSUS=true          # Require consensus before PASS decision
DUAL_ENABLE_STATISTICAL_ANALYSIS=true

# Model selection
DUAL_USE_DUAL_MODEL=true             # false → single Gemini model only
DUAL_GEMINI_MODEL=gemini-2.5-flash-preview-04-17
DUAL_GROQ_MODEL=llama-3.3-70b-versatile

# Rate-limit handling and graceful degradation (Req 8.2, 8.3)
DUAL_GROQ_RATE_LIMIT_RETRIES=3      # Retries on Groq rate-limit errors
DUAL_GROQ_BACKOFF_BASE=2.0          # Exponential backoff base (seconds)
DUAL_GEMINI_RATE_LIMIT_RETRIES=3
DUAL_GEMINI_BACKOFF_BASE=2.0
DUAL_SINGLE_MODEL_FALLBACK=true     # Fall back to single model on API failure

# Performance (Req 8.4)
DUAL_PROCESSING_TIMEOUT=30.0        # Alert threshold in seconds

# Distributed processing (Req 8.5)
DUAL_INSTANCE_ID=default            # Unique ID per horizontal instance
DUAL_DISTRIBUTED_MODE=false         # Enable distributed coordination

# Alerting thresholds (Req 2.5, 5.5)
DUAL_ALERT_DISAGREEMENT_THRESHOLD=0.5   # Alert when disagreement > this value
DUAL_ALERT_CONSECUTIVE_FAILURES=3       # Alert after N consecutive model failures